# Environment Mode Configuration
# Options: development | production
# Secure-by-default: If not set to "development", it runs strictly in "production".
ENV=development

# SMTP Server Configuration (e.g. smtp.gmail.com)
SMTP_SERVER=smtp.gmail.com

# SMTP Port Configuration (587 for TLS/starttls, 465 for SSL/SMTP_SSL)
SMTP_PORT=587

# SMTP Authentication Username (your full Gmail address)
SMTP_USER=antonetteagustin05@gmail.com
# SMTP_USER=capstone2026to2027@gmail.com

# SMTP Authentication Password (your Gmail 16-character App Password, NOT normal password)
SMTP_PASSWORD=guio djpm rnbt xfvn
